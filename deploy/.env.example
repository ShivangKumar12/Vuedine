# ============================================================
#  Vuedine production env — copy to `deploy/.env` and fill in.
#  This file is read by docker compose (for ${...} interpolation) AND
#  passed to the api/worker containers. Keep it secret (chmod 600).
#
#  Generate each secret with:
#     openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 48
# ============================================================

# ---- Domain / TLS (used by Caddy) ----
DOMAIN=vuedine.in
API_DOMAIN=api.vuedine.in
ACME_EMAIL=admin@vuedine.in

# ---- Database ----
# DATABASE_URL is composed from this in docker-compose.yml — set it once here.
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---- Auth secrets (min 32 chars each) ----
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret_xxxxxxxx
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret_xxxxxxx
FIELD_ENCRYPTION_KEY=CHANGE_ME_min_32_chars_field_encryption_key
METRICS_AUTH_TOKEN=CHANGE_ME_metrics_token

# ---- App ----
NODE_ENV=production
LOG_LEVEL=info
BCRYPT_COST=12

# HTTPS-only in production (enforced at boot). Origins that may call the API.
CORS_ORIGINS=https://vuedine.in,https://www.vuedine.in

# Public URLs the QR resolver + guest PWA use.
PUBLIC_QR_BASE=https://api.vuedine.in
PUBLIC_APP_URL=https://vuedine.in

# Rate limits (per IP)
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=900000

# ---- Email (recommended — invites, password resets, exports, dunning) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vuedine <noreply@vuedine.in>"

# ---- Object storage for uploads (optional; logo/banner/exports) ----
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ---- Web Push (optional; generate with: npx web-push generate-vapid-keys) ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@vuedine.in

# ---- Error tracking (optional) ----
SENTRY_DSN=

# ---- Observability ----
PROMETHEUS_ENABLED=true
