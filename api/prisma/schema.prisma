// ============================================================
//  Vuedine — base schema (Phase 2)
//
//  Adds the multi-tenant backbone (Tenant, Branch, User) plus the
//  auth & audit tables that Phase 4 will plug into.
//
//  Conventions documented in BACKEND_PHASES.md Phase 2:
//   - cuid PKs (sortable, URL-safe)
//   - createdAt / updatedAt / deletedAt for soft delete
//   - Every business table carries tenantId (composite indexes lead with it)
//   - Money is Decimal(12,2) (lands in Phase 5+ when orders/payments arrive)
//   - timestamps are timestamptz (Prisma's default DateTime)
//
//  Decision: see api/docs/decisions/0001-orm.md, 0002-multi-tenancy.md
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  Enums
// ============================================================

enum UserRole {
  SUPER_ADMIN // Vuedine platform staff
  OWNER // tenant owner
  ADMIN // tenant admin
  MANAGER
  CASHIER
  WAITER
  CHEF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditAction {
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_LOGIN_FAILED
  AUTH_REFRESH
  AUTH_PASSWORD_RESET
  AUTH_TOKEN_REUSE_DETECTED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  TENANT_CREATED
  BRANCH_CREATED
  BRANCH_UPDATED
  BRANCH_DELETED
  BRANCH_TOGGLED_LIVE
  TABLE_CREATED
  TABLE_UPDATED
  TABLE_DELETED
  TABLE_QR_REGENERATED
  ITEM_CREATED
  ITEM_UPDATED
  ITEM_DELETED
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_STATUS_CHANGED
  ORDER_CANCELLED
  ORDER_REFIRED
  ORDER_LINE_PREPARED
  TABLE_SESSION_OPENED
  TABLE_SESSION_CLOSED
  TABLE_SESSION_TRANSFERRED
  TABLE_SESSION_MERGED
  KDS_TICKET_BUMPED
  KDS_TICKET_RECALLED
  GUEST_RING_WAITER
  GUEST_REQUEST_BILL
  GUEST_FEEDBACK
  PAYMENT_CAPTURED
  PAYMENT_REFUNDED
  PAYMENT_FAILED
  PAYMENT_COMP
  PAYMENT_TIP
  SETTLEMENT_SYNCED
  PAYMENT_SETTINGS_UPDATED
  PROMOTION_CREATED
  PROMOTION_UPDATED
  PROMOTION_DELETED
  PROMOTION_REDEEMED
  PROMOTION_PAUSED
  PROMOTION_RESUMED
  PROMOTION_EXPIRED
  PROMOTION_ACTIVATED
  SETTINGS_CHANGED
  PERMISSION_CHANGED
  USER_INVITED
  USER_INVITE_ACCEPTED
  USER_SUSPENDED
  USER_RESTORED
  USER_PIN_RESET
  USER_PIN_VERIFIED
  USER_PIN_LOCKED
  USER_ROLE_ASSIGNED
  CUSTOMER_TAGGED
  CUSTOMER_PREFERENCES_UPDATED
  CUSTOMER_ANONYMIZED
  SHIFT_STARTED
  SHIFT_ENDED
  API_KEY_ISSUED
  API_KEY_REVOKED
  TAX_SLAB_CREATED
  TAX_SLAB_UPDATED
  TAX_SLAB_DELETED
  PAYMENT_METHOD_CONFIG_CHANGED
  HARDWARE_DEVICE_CREATED
  HARDWARE_DEVICE_UPDATED
  HARDWARE_DEVICE_DELETED
  HARDWARE_DEVICE_PAIRED
  NOTIFICATION_PREFS_CHANGED
  TENANT_DATA_EXPORTED
  TENANT_ANONYMIZED
  QR_CODE_CREATED
  QR_CODE_UPDATED
  QR_CODE_DELETED
  QR_CODE_REGENERATED
  CAMPAIGN_CREATED
