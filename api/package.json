{
  "name": "vuedine-api",
  "version": "0.1.0",
  "private": true,
  "description": "Vuedine restaurant POS — backend API",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:cluster": "pm2-runtime ecosystem.config.cjs",
    "start:worker": "node src/queues/workers/index.js",
    "build": "echo 'pure JS — nothing to build'",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml}\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:db:setup": "dotenv -e .env.test -- npx prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js",
    "queue:board": "node scripts/bull-board.js",
    "audit": "audit-ci --config audit-ci.json",
    "security:routes": "node scripts/audit-routes.js",
    "docs:generate": "node src/docs/generate.js",
    "docs:validate": "swagger-cli validate docs/openapi.json",
    "prepare": "node scripts/setup-husky.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1064.0",
    "@aws-sdk/s3-request-presigner": "^3.1064.0",
    "@bull-board/api": "^7.2.1",
    "@bull-board/express": "^7.2.1",
    "@prisma/client": "^6.19.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "http_ece": "^1.2.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "papaparse": "^5.4.1",
    "pdfkit": "^0.15.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^11.2.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.5",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@faker-js/faker": "^10.4.0",
    "audit-ci": "^7.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.4.2",
    "jest-extended": "^7.0.0",
    "lint-staged": "^15.4.1",
    "nodemon": "^3.1.9",
    "openapi-to-postmanv2": "^6.1.0",
    "pm2": "^7.0.1",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "vuedine",
    "restaurant",
    "pos",
    "api",
    "express",
    "prisma"
  ],
  "author": "Vuedine Engineering <eng@vuedine.com>",
  "license": "UNLICENSED"
}
