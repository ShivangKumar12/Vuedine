# ============================================================
#  Vuedine monorepo — root ignore rules.
#  Per-package rules also live in api/.gitignore and app/.gitignore.
# ============================================================

# Dependencies
**/node_modules/
.pnp
.pnp.js

# Secrets — NEVER commit real env files
**/.env
**/.env.*
!**/.env.example

# Build output
**/dist/
**/build/
**/coverage/
**/.nyc_output/
**/*.tsbuildinfo

# Generated API docs (regenerated by `npm run docs:generate`)
api/docs/openapi.json
api/docs/postman.json

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Prisma local artifacts
api/prisma/*.db
api/prisma/migrations/dev.db*

# Editor / OS
.idea/
.DS_Store
Thumbs.db
*.swp

# Caches
**/.eslintcache
**/.cache/
**/.vite/

# Docker local overrides
**/docker-compose.override.local.yml

# Deploy bookkeeping
.deployed-sha

# Local audit / scratch helpers
_audit.ps1
_audit.txt
test-results.txt
api/scripts/run-all-tests.ps1
